# ==================== 应用核心 ====================
APP_NAME=backend
APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=true

# ==================== 数据库 ====================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=agentictour

# ==================== Auth (JWT) ====================
# 设 DEBUG=true 时跳过 JWT 校验，所有请求默认以 user_id=1 的身份执行
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==================== Dify 通用 ====================
DIFY_API_KEY=
DIFY_URL=
DIFY_TIMEOUT=600

# ==================== Dify 工作流 - 行程计划生成/修订 ====================
DIFY_TRIP_PLAN_API_KEY=
DIFY_TRIP_PLAN_URL=

# ==================== Dify 工作流 - 说人话 ====================
DIFY_HUMANIZE_API_KEY=
DIFY_HUMANIZE_URL=

# ==================== Dify 工作流 - 博客创作 ====================
DIFY_BLOG_API_KEY=
DIFY_BLOG_URL=
DIFY_BLOG_FILE_UPLOAD_URL=

# ==================== Dify 知识库 ====================
DIFY_KNOWLEDGE_URL=http://host.docker.internal:3000/v1
DIFY_KNOWLEDGE_API_KEY=
DIFY_KNOWLEDGE_DATASET_ID=

# ==================== Dify 知识库直连 PostgreSQL (偏好分析) ====================
DIFY_DB_URL=postgresql://postgres:difyai123456@host.docker.internal:5432/dify

# ==================== Hikari 旅行陪伴 ====================
Hikari_key=
HIKARI_DIFY_URL=
HIKARI_CHAT_HISTORY_MAX_MESSAGES=20
HIKARI_CHAT_HISTORY_MAX_CHARS=12000
HIKARI_ADVICE_HISTORY_MAX_VERSIONS=10
HIKARI_ADVICE_HISTORY_MAX_CHARS=12000

# 浏览器定位（WGS84）转高德坐标并逆地理编码
AMAP_KEY=
AMAP_BASE_URL=https://restapi.amap.com
AMAP_TIMEOUT=10

# ==================== 审核工作流 ====================
check_key=
CHECK_DIFY_URL=

# ==================== 操作日志 ====================
OPERATION_LOG_DIR=/app/logs

# ==================== 博客图片上传 ====================
BLOG_UPLOAD_DIR=/app/uploads/blog
