APP_NAME=backend
APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=true

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=agentictour

# -------------------- Auth (JWT) --------------------
# 设 DEBUG=true 时跳过 JWT 校验，所有请求默认以 user_id=1 的身份执行
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

DIFY_TIMEOUT=120

DIFY_TRIP_PLAN_API_KEY=
DIFY_TRIP_PLAN_URL=

DIFY_HUMANIZE_API_KEY=
DIFY_HUMANIZE_URL=

DIFY_BLOG_API_KEY=
DIFY_BLOG_URL=

DIFY_KNOWLEDGE_API_KEY=
DIFY_KNOWLEDGE_URL=
DIFY_KNOWLEDGE_DATASET_ID=

Hikari_key=
check_key=
HIKARI_DIFY_URL=https://api.dify.ai/v1/workflows/run
CHECK_DIFY_URL=https://api.dify.ai/v1/workflows/run

# Hikari 发送给 Dify 的历史上下文窗口；0 表示不传历史。
HIKARI_CHAT_HISTORY_MAX_MESSAGES=20
HIKARI_CHAT_HISTORY_MAX_CHARS=12000
